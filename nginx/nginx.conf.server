events {}

http {
    include mime.types;

    server {
        listen 80;
        listen 443;
        server_name editorium.net www.editorium.net;

#         location /api {
#             proxy_pass http://nest_api:3002/;
#         }

        location /editor/ {
            proxy_pass http://editor:3000/;
            rewrite ^\/editor\/(.*) /$1 break;
        }

        location /test {
            return 200 'Hello from Test';
        }
    }
}