server {
    listen 80;

    server_name editorium.dev;

    location /api {
        proxy_pass http://editor_api:3001;
    }
    location / {
        proxy_pass http://editor:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}